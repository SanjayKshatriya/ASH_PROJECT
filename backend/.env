# ============================================================
# AgroSmartHub 3.0 — Environment Configuration
# ============================================================

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5000

# ─── SUPABASE ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
#
#  SUPABASE_URL         → "Project URL"  (e.g. https://xxxx.supabase.co)
#  SUPABASE_ANON_KEY    → "anon / public" key  (starts with eyJ...)
#  SUPABASE_SERVICE_ROLE_KEY → "service_role" secret key  (starts with eyJ...)
#
# ⚠️  Keys that start with sb_publishable_ or sb_secret_ are WRONG.
#    Only JWT-format keys (eyJ...) are accepted by @supabase/supabase-js v2.
# ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://mekkljheshjekexwpnso.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1la2tsamhlc2hqZWtleHdwbnNvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM1NzkwMDYsImV4cCI6MjA5OTE1NTAwNn0.Get9ubjdWljwue76eKSZrK5PTJO5LJ_zH_H7EBrdxC8
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1la2tsamhlc2hqZWtleHdwbnNvIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MzU3OTAwNiwiZXhwIjoyMDk5MTU1MDA2fQ.y4xC0RSmOMFACkRyLtVsaVSNnOCHABOmCxmTRGasocM

# ─── DATABASE (via Supabase Transaction Pooler) ───────────────
# Get from: Supabase Dashboard → Settings → Database → Connection Pooling
# Use "Transaction" mode, port 6543
# Replace [YOUR-PASSWORD] with your Supabase DB password
DATABASE_URL=postgresql://postgres.mekkljheshjekexwpnso:SanjayKshatriya%407@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ─── REDIS ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_2025_agrismarthub
JWT_EXPIRES_IN=7d

# ─── TWILIO (OTP) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── EMAIL (Nodemailer) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=AgroSmartHub <noreply@agrismarthub.com>

# ─── RAZORPAY (Payments) ──────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── AWS S3 (File Storage) ────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=agrismarthub-uploads
AWS_REGION=ap-south-1

# ─── FIREBASE (Push Notifications) ────────────────────────────
FIREBASE_PROJECT_ID=agrismarthub-app
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@agrismarthub.iam.gserviceaccount.com

# ─── WEATHER API ──────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweathermap_key

# ─── AI MODEL ─────────────────────────────────────────────────
AI_MODEL_URL=http://localhost:8000/predict
AI_API_KEY=your_ai_model_key

# ─── BLOCKCHAIN ───────────────────────────────────────────────
BLOCKCHAIN_API_URL=https://blockchain-api.agrismarthub.com
BLOCKCHAIN_API_KEY=your_blockchain_key

# ─── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log
