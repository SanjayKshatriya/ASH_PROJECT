# ============================================================
# AgroSmartHub 3.0 — .gitignore
# ============================================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (keep .env.example)
backend/.env
.env
*.env

# Logs
logs/
*.log

# Android local config (machine-specific)
android/local.properties
android/.gradle/
android/build/
android/app/build/
android/**/*.iml
android/.idea/

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Generated test output (kept in Excel files committed to repo)
gh-pages-deploy/

# IDE
.vscode/settings.json
*.suo
*.user
