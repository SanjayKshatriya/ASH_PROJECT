{
  "name": "agrosmart-e2e",
  "version": "1.0.0",
  "description": "Appium E2E Test Suite for AgroSmartHub 3.0",
  "scripts": {
    "test": "wdio run wdio.conf.js",
    "test:ci": "wdio run wdio.conf.js --logLevel error",
    "report:html": "node scripts/generate-html-report.js",
    "report:excel": "node scripts/generate-excel-report.js",
    "report:summary": "node scripts/generate-summary.js",
    "report:all": "npm run report:html && npm run report:excel && npm run report:summary",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "dependencies": {
    "@wdio/allure-reporter": "^8.32.0",
    "@wdio/appium-service": "^8.32.0",
    "@wdio/cli": "^8.32.0",
    "@wdio/local-runner": "^8.32.0",
    "@wdio/mocha-framework": "^8.32.0",
    "@wdio/spec-reporter": "^8.32.0",
    "appium": "^2.5.4",
    "appium-uiautomator2-driver": "^3.5.0",
    "chai": "^4.4.1",
    "exceljs": "^4.4.0",
    "fs-extra": "^11.2.0",
    "webdriverio": "^8.32.0"
  },
  "devDependencies": {
    "allure-commandline": "^2.27.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
